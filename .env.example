# Resend (booking confirmation emails)
# RESEND_API_KEY=
# RESEND_FROM_EMAIL=
# ADMIN_EMAIL=

# Optional: Twilio WhatsApp — admin alerts for new public bookings and cancellations
# (same triggers as admin Resend). Join the Twilio WhatsApp sandbox from the admin phone first.
# ADMIN_WHATSAPP_PHONE=+31687630005
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
# Must differ from ADMIN_WHATSAPP_PHONE (From = Twilio’s line, To = your phone).
