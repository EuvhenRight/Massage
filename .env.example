# Resend (booking confirmation emails)
# RESEND_API_KEY=
# RESEND_FROM_EMAIL=
# ADMIN_EMAIL=

# Optional: Twilio WhatsApp — admin (public new + all cancels) and customer (new + cancel when phone is +E.164).
# Sandbox: each receiving handset must send "join <code>" to Twilio’s sandbox number from WhatsApp (admin + each customer number).
#
# ADMIN_WHATSAPP_PHONE=+420123456789
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
#
# TWILIO_WHATSAPP_FROM = Twilio’s sender (Console → Messaging → Try WhatsApp / Sandbox “From” — NOT your personal number).
# ADMIN_WHATSAPP_PHONE = your mobile in E.164 that receives alerts (must have joined sandbox).
# Errors: 63007 = wrong From or wrong Twilio account; 63016 = phone did not send “join …” to sandbox; 63031 = From and To are the same.
