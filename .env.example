# Required in production for Google: canonical URLs, sitemap.xml, robots.txt, Open Graph, JSON-LD.
# Use your real public domain with HTTPS, no trailing slash (not *.vercel.app if you have a custom domain).
# NEXT_PUBLIC_SITE_URL=https://v2studio.sk

# Optional: Google Search Console verification content value
# NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=

# Social / link-preview SEO (Facebook, WhatsApp, Instagram, LinkedIn, X, Telegram use Open Graph + Twitter tags)
# X (Twitter): @handle without or with @ — used for twitter:site / twitter:creator
# NEXT_PUBLIC_TWITTER_SITE=V2studio
# NEXT_PUBLIC_TWITTER_CREATOR=V2studio
# Facebook app (fb:app_id) — Meta for Developers → your app
# NEXT_PUBLIC_FACEBOOK_APP_ID=
# Optional extra og:see_also targets
# NEXT_PUBLIC_LINKEDIN_URL=https://www.linkedin.com/company/...
# NEXT_PUBLIC_TELEGRAM_URL=https://t.me/yourchannel

# Resend (booking confirmation emails)
# RESEND_API_KEY=
# RESEND_FROM_EMAIL=
# ADMIN_EMAIL=

# Twilio WhatsApp — staff alert per booking (by place) + customer messages via approved Content Templates.
# Sandbox: each receiving handset must send "join <code>" to Twilio's sandbox number from WhatsApp.
#
# ADMIN_WHATSAPP_PHONE=+421952133257
# DEPILATION_MASTER_WHATSAPP_PHONE=+421952133258
# MASSAGE_MASTER_WHATSAPP_PHONE=
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_MESSAGING_SERVICE_SID=whatsapp:+14155238886
#
# Twilio Content Template SIDs (HX...) — create in Console → Content Builder, all must be approved.
# Without these, customer/staff WhatsApp messages are skipped (free-form Body= no longer used).
# TWILIO_CONTENT_SID_BOOKING_NEW=
# TWILIO_CONTENT_SID_BOOKING_CANCELLED=
# TWILIO_CONTENT_SID_BOOKING_RESCHEDULED=
# TWILIO_CONTENT_SID_REMINDER_2D=
# TWILIO_CONTENT_SID_REMINDER_1D=
# TWILIO_CONTENT_SID_REMINDER_1H=
# TWILIO_CONTENT_SID_STAFF_NEW=
# TWILIO_CONTENT_SID_STAFF_CANCELLED=
#
# TWILIO_MESSAGING_SERVICE_SID = Twilio's WhatsApp sender (Console → Messaging → Try WhatsApp — NOT your SK mobile).
# Routing: bookingPlace=massage → MASSAGE_MASTER_WHATSAPP_PHONE or ADMIN_WHATSAPP_PHONE. bookingPlace=depilation → DEPILATION_MASTER_WHATSAPP_PHONE or ADMIN (fallback).
# Errors: 63007 = wrong From or wrong Twilio account; 63016 = phone did not send "join …" to sandbox; 63018 = template not approved / variables mismatch; 63031 = From and To are the same.
