rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Services: read for public booking + admin, write for all
    match /services/{document} {
      allow read, write: if true;
    }

    // Schedule: read for public booking, write for admin
    match /schedule/{document} {
      allow read, write: if true;
    }

    // Appointments & days: adjust as needed for your auth setup
    match /appointments/{document} {
      allow read, write: if true;
    }
    match /days/{document} {
      allow read, write: if true;
    }

    // Price catalog: read for public Price page, write via API (auth checked in route)
    match /priceCatalog/{document} {
      allow read, write: if true;
    }

    // Clients: customer profile cards (birthday, opt-ins, visit history).
    // Public read/write to keep the rule shape consistent with appointments;
    // tighten alongside the broader admin-auth migration when that lands.
    match /clients/{document} {
      allow read, write: if true;

      // Per-client CRM timeline written by the booking status orchestrator
      // and reminder cron. Same access shape as the parent doc.
      match /activity/{activityId} {
        allow read, write: if true;
      }
    }

    // Booking audit log: append-only history written by route handlers, cron
    // jobs, and the booking status orchestrator. Same open access shape as
    // the rest of the collections until the admin-auth migration lands.
    match /booking_audit/{document} {
      allow read, write: if true;
    }
  }
}
